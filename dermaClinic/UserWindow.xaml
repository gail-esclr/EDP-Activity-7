<Window x:Class="dermaClinic.UserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add New Account" Height="650" Width="500" 
        WindowStartupLocation="CenterScreen" Background="Transparent" 
        AllowsTransparency="True" WindowStyle="None">

    <Border Background="White" CornerRadius="20" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.1" ShadowDepth="0" Color="Black"/>
        </Border.Effect>
        
        <Grid Margin="35">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0">
                <TextBlock x:Name="lblTitle" Text="Add New Account" FontFamily="Georgia" FontSize="36" FontWeight="Bold" Foreground="#A32A53"/>
                <TextBlock Text="Enter account information below." Foreground="#888" FontSize="16" Margin="0,5,0,30"/>
            </StackPanel>
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="USERNAME" Foreground="#888" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                    <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" Margin="0,0,0,20">
                        <TextBox x:Name="txtUsername" Padding="10" BorderThickness="0" FontSize="14"/>
                    </Border>
                    <TextBlock Text="EMAIL ADDRESS" Foreground="#888" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                    <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" Margin="0,0,0,20">
                        <TextBox x:Name="txtEmail" Padding="10" BorderThickness="0" FontSize="14"/>
                    </Border>
                    <TextBlock Text="PASSWORD" Foreground="#888" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                    <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" Margin="0,0,0,5">
                        <TextBox x:Name="txtPassword" Padding="10" BorderThickness="0" FontSize="14"/>
                    </Border>
                    <TextBlock x:Name="lblPassHint" Text="Password is required for new users." Foreground="#E74C3C" FontSize="11" Margin="0,0,0,20"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="ROLE" Foreground="#888" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                            <ComboBox x:Name="cmbRole" Padding="10" Height="45" VerticalContentAlignment="Center">
                                <ComboBoxItem Content="Doctor" IsSelected="True"/>
                                <ComboBoxItem Content="Staff"/>
                                <ComboBoxItem Content="Admin"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="STATUS" Foreground="#888" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                            <ComboBox x:Name="cmbStatus" Padding="10" Height="45" VerticalContentAlignment="Center">
                                <ComboBoxItem Content="Active" IsSelected="True"/>
                                <ComboBoxItem Content="Inactive"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="btnCancel" Click="btnCancel_Click" Content="CANCEL" Background="Transparent" Foreground="#888" FontWeight="Bold" Margin="0,0,20,0" BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="btnSave" Click="btnSave_Click" Content="SAVE CHANGES" Background="#A32A53" Foreground="White" FontWeight="Bold" Padding="25,12" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="25">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="25,12"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
