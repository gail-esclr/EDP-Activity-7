<Window x:Class="dermaClinic.AppointmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add New Appointment" Height="750" Width="500" 
        WindowStartupLocation="CenterScreen" Background="Transparent" 
        AllowsTransparency="True" WindowStyle="None">

    <Border Background="White" CornerRadius="20" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.1" ShadowDepth="0" Color="Black"/>
        </Border.Effect>
        
        <Grid Margin="35">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0">
                <TextBlock x:Name="lblTitle" Text="New Appointment" FontFamily="Georgia" FontSize="36" FontWeight="Bold" Foreground="#A32A53"/>
                <TextBlock Text="Schedule a clinical visit below." Foreground="#888" FontSize="16" Margin="0,5,0,30"/>
            </StackPanel>
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="SELECT PATIENT" Foreground="#888" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                    <ComboBox x:Name="cmbPatient" Padding="10" Height="45" VerticalContentAlignment="Center" Margin="0,0,0,20" DisplayMemberPath="full_name" SelectedValuePath="patient_id"/>
                    <TextBlock Text="SELECT DOCTOR" Foreground="#888" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                    <ComboBox x:Name="cmbDoctor" Padding="10" Height="45" VerticalContentAlignment="Center" Margin="0,0,0,20" DisplayMemberPath="full_name" SelectedValuePath="doctor_id"/>
                    <TextBlock Text="SELECT SERVICE" Foreground="#888" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                    <ComboBox x:Name="cmbService" Padding="10" Height="45" VerticalContentAlignment="Center" Margin="0,0,0,20" DisplayMemberPath="service_name" SelectedValuePath="service_id"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="DATE" Foreground="#888" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                            <DatePicker x:Name="dpDate" Height="45" Padding="5" VerticalContentAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="TIME" Foreground="#888" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                            <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="5">
                                <TextBox x:Name="txtTime" Padding="10" BorderThickness="0" FontSize="14" Text="10:00:00"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="STATUS" Foreground="#888" FontSize="12" FontWeight="Bold" Margin="0,20,0,8"/>
                    <ComboBox x:Name="cmbStatus" Padding="10" Height="45" VerticalContentAlignment="Center">
                        <ComboBoxItem Content="Pending" IsSelected="True"/>
                        <ComboBoxItem Content="Confirmed"/>
                        <ComboBoxItem Content="Cancelled"/>
                        <ComboBoxItem Content="Completed"/>
                    </ComboBox>
                </StackPanel>
            </ScrollViewer>
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="btnCancel" Click="btnCancel_Click" Content="CANCEL" Background="Transparent" Foreground="#888" FontWeight="Bold" Margin="0,0,20,0" BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="btnSave" Click="btnSave_Click" Content="CONFIRM BOOKING" Background="#A32A53" Foreground="White" FontWeight="Bold" Padding="25,12" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="25">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="25,12"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
