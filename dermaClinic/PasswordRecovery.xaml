<Window x:Class="dermaClinic.PasswordRecovery"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recover Password" Height="720" Width="1280" 
        WindowStartupLocation="CenterScreen" WindowState="Maximized" Background="White">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.5*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="#FDECEF">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid Width="140" Height="140" Margin="0,0,0,30">
                    <Ellipse Fill="White"/>
                    <Image Source="logo.png" Width="130" Height="130" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image.Clip>
                            <EllipseGeometry Center="65,65" RadiusX="65" RadiusY="65"/>
                        </Image.Clip>
                    </Image>
                </Grid>

                <TextBlock Text="D E R M A C A R E" FontFamily="Georgia" FontSize="36" Foreground="#333" HorizontalAlignment="Center"/>
                <TextBlock Text="D E R M A   C L I N I C" FontSize="12" Foreground="#888" HorizontalAlignment="Center" Margin="0,15,0,0" />

                <Border Height="1" Background="#D5C5C9" Width="180" Margin="0,30,0,30" />

                <TextBlock Text="C A R E   F O R   Y O U R   S K I N ," FontSize="11" Foreground="#888" HorizontalAlignment="Center" Margin="0,0,0,5" FontWeight="Medium"/>
                <TextBlock Text="L O V E   Y O U R   G L O W ." FontSize="11" Foreground="#888" HorizontalAlignment="Center" FontWeight="Medium"/>
            </StackPanel>
        </Grid>
        <Grid Grid.Column="1" Margin="80,0">
            <StackPanel VerticalAlignment="Center" MaxWidth="400">
                <TextBlock Text="Forgot Password?" FontFamily="Georgia"  FontSize="42"  Foreground="#333" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="Enter your email to reset your password" FontSize="14" Foreground="Gray" HorizontalAlignment="Center" Margin="0,0,0,45"/>
                <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" Margin="0,0,0,25" Padding="0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Path Grid.Column="0" 
              Data="M20,8L12,13L4,8V6L12,11L20,6M20,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V6C22,4.89 21.1,4 20,4Z" 
              Fill="#B0B0B0" Width="18" Height="14" Stretch="Fill" 
              VerticalAlignment="Center" HorizontalAlignment="Center"/>

                        <TextBlock Grid.Column="1" Text="Email Address" Foreground="#B0B0B0" 
                   VerticalAlignment="Center" IsHitTestVisible="False" FontSize="16">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=txtEmail}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <TextBox x:Name="txtEmail" Grid.Column="1" Background="Transparent" 
                 BorderThickness="0" VerticalContentAlignment="Center" 
                 FontSize="16" Foreground="#333"/>
                    </Grid>
                </Border>
                <Button x:Name="btnSend" Click="btnSend_Click" Content="PROCEED TO RESET" Background="#A32A53" Foreground="White" Height="55" FontSize="18" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,35,0,0">
                    <TextBlock Text="Remember your password? " Foreground="Gray"/>
                    <TextBlock x:Name="btnBackToLogin" MouseLeftButtonDown="btnBackToLogin_Click" Text="Back to Login" Foreground="#A32A53" Cursor="Hand" FontWeight="SemiBold"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>