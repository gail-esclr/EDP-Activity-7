<Window x:Class="dermaClinic.MainWindow"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       Title="DermaCare Login" Height="720" Width="1280" 
       WindowStartupLocation="CenterScreen" WindowState="Maximized" Background="White">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.5*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="#FDECEF">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid Width="140" Height="140" Margin="0,0,0,30">
                    <Ellipse Fill="White"/>
                    <Image Source="logo.png" Width="130" Height="130" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image.Clip>
                            <EllipseGeometry Center="65,65" RadiusX="65" RadiusY="65"/>
                        </Image.Clip>
                    </Image>
                </Grid>

                <TextBlock Text="D E R M A C A R E" FontFamily="Georgia" FontSize="36" Foreground="#333" HorizontalAlignment="Center"/>
                <TextBlock Text="D E R M A   C L I N I C" FontSize="12" Foreground="#888" HorizontalAlignment="Center" Margin="0,15,0,0" />

                <Border Height="1" Background="#D5C5C9" Width="180" Margin="0,30,0,30" />

                <TextBlock Text="C A R E   F O R   Y O U R   S K I N ," FontSize="11" Foreground="#888" HorizontalAlignment="Center" Margin="0,0,0,5" FontWeight="Medium"/>
                <TextBlock Text="L O V E   Y O U R   G L O W ." FontSize="11" Foreground="#888" HorizontalAlignment="Center" FontWeight="Medium"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1" Background="White">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="380">
                <TextBlock Text="Welcome" FontFamily="Georgia" FontSize="42" Foreground="#333" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="Please enter your details to sign in" FontSize="14" Foreground="#888" HorizontalAlignment="Center" Margin="0,0,0,45"/>

                <Border Background="#F9F9F9" CornerRadius="4" Height="50" Margin="0,0,0,15" BorderBrush="#EFEFEF" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Path Grid.Column="0" Data="M20,8L12,13L4,8V6L12,11L20,6M20,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V6C22,4.89 21.1,4 20,4Z" 
                              Fill="#B0B0B0" Width="18" Height="14" Stretch="Fill" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Username" Foreground="#B0B0B0" VerticalAlignment="Center" IsHitTestVisible="False" FontSize="14">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=txtUsername}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox x:Name="txtUsername" Grid.Column="1" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" FontSize="14" Foreground="#333"/>
                    </Grid>
                </Border>

                <Border Background="#F9F9F9" CornerRadius="4" Height="50" Margin="0,0,0,20" BorderBrush="#EFEFEF" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <Path Grid.Column="0" Data="M12,17A2,2 0 0,0 14,15C14,13.89 13.1,13 12,13A2,2 0 0,0 10,15A2,2 0 0,0 12,17M18,8A2,2 0 0,1 20,10V20A2,2 0 0,1 18,22H6A2,2 0 0,1 4,20V10C4,8.89 4.9,8 6,8H7V6A5,5 0 0,1 12,1A5,5 0 0,1 17,6V8H18M12,3A3,3 0 0,0 9,6V8H15V6A3,3 0 0,0 12,3Z" 
                              Fill="#B0B0B0" Width="14" Height="18" Stretch="Fill" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Password" Foreground="#B0B0B0" VerticalAlignment="Center" IsHitTestVisible="False" FontSize="14">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsKeyboardFocused, ElementName=txtPassword}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <PasswordBox x:Name="txtPassword" Grid.Column="1" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" FontSize="14" Foreground="#333"/>
                        <Path x:Name="btnShowPass" Grid.Column="2" Data="M11.83,9L15,12.16C15,12.11 15,12.05 15,12A3,3 0 0,0 12,9C11.94,9 11.89,9 11.83,9M7.53,9.8L9.08,11.35C9.03,11.56 9,11.77 9,12A3,3 0 0,0 12,15C12.22,15 12.44,14.97 12.65,14.92L14.2,16.47C13.53,16.8 12.79,17 12,17A5,5 0 0,1 7,12C7,11.21 7.2,10.47 7.53,9.8M2,4.27L4.28,6.55L4.73,7C3.08,8.3 1.78,10 1,12C2.73,16.39 7,19.5 12,19.5C13.55,19.5 15.03,19.2 16.38,18.66L16.81,19.08L19.73,22L21,20.73L3.27,3M12,7A5,5 0 0,1 17,12C17,12.64 16.87,13.26 16.64,13.82L19.57,16.75C21.07,15.5 22.27,13.86 23,12C21.27,7.61 17,4.5 12,4.5C10.6,4.5 9.26,4.75 8,5.2L10.17,7.35C10.74,7.13 11.35,7 12,7Z" 
                              Fill="#B0B0B0" Width="20" Height="16" Stretch="Fill" VerticalAlignment="Center" HorizontalAlignment="Center" Cursor="Hand"/>
                    </Grid>
                </Border>

                <Grid Margin="0,0,0,25">
                    <CheckBox Content="Remember me" VerticalAlignment="Center" Foreground="#888" FontSize="13"/>
                    <TextBlock Text="Forgot Password?" MouseLeftButtonDown="ForgotPassword_Click" HorizontalAlignment="Right" Foreground="#A32A53" Cursor="Hand" FontSize="13" VerticalAlignment="Center"/>
                </Grid>

                <Button x:Name="btnLogin" Click="btnLogin_Click" Content="SIGN IN" Background="#A32A53" Foreground="White" Height="50" FontSize="14" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#862342"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,35,0,0">
                    <TextBlock Text="System issue? " Foreground="#888" FontSize="12"/>
                    <TextBlock Text="Contact Admin" Foreground="#A32A53" Cursor="Hand" FontWeight="SemiBold" FontSize="12"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>