<Window x:Class="dermaClinic.ServiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add New Service" Height="600" Width="500" 
        WindowStartupLocation="CenterScreen" Background="Transparent" 
        AllowsTransparency="True" WindowStyle="None">

    <Border Background="White" CornerRadius="20" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.1" ShadowDepth="0" Color="Black"/>
        </Border.Effect>
        
        <Grid Margin="35">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0">
                <TextBlock x:Name="lblTitle" Text="Add New Service" FontFamily="Georgia" FontSize="36" FontWeight="Bold" Foreground="#A32A53"/>
                <TextBlock Text="Enter clinical treatment details below." Foreground="#888" FontSize="16" Margin="0,5,0,30"/>
            </StackPanel>
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="SERVICE NAME" Foreground="#888" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                    <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" Margin="0,0,0,20">
                        <TextBox x:Name="txtServiceName" Padding="10" BorderThickness="0" FontSize="14"/>
                    </Border>
                    <TextBlock Text="PRICE (PHP)" Foreground="#888" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                    <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" Margin="0,0,0,20">
                        <TextBox x:Name="txtPrice" Padding="10" BorderThickness="0" FontSize="14"/>
                    </Border>
                    <TextBlock Text="DESCRIPTION" Foreground="#888" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                    <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" Margin="0,0,0,20">
                        <TextBox x:Name="txtDescription" Padding="10" MinHeight="100" TextWrapping="Wrap" BorderThickness="0" FontSize="14"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="btnCancel" Click="btnCancel_Click" Content="CANCEL" Background="Transparent" Foreground="#888" FontWeight="Bold" Margin="0,0,20,0" BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="btnSave" Click="btnSave_Click" Content="SAVE CHANGES" Background="#A32A53" Foreground="White" FontWeight="Bold" Padding="25,12" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="25">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="25,12"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
