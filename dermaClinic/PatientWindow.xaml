<Window x:Class="dermaClinic.PatientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add New Patient" Height="750" Width="500" 
        WindowStartupLocation="CenterScreen" Background="Transparent" 
        AllowsTransparency="True" WindowStyle="None">

    <Border Background="White" CornerRadius="20" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.1" ShadowDepth="0" Color="Black"/>
        </Border.Effect>
        
        <Grid Margin="35">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0">
                <TextBlock x:Name="lblTitle" Text="Add New Patient" FontFamily="Georgia" FontSize="36" FontWeight="Bold" Foreground="#A32A53"/>
                <TextBlock Text="Enter patient information below." Foreground="#888" FontSize="16" Margin="0,5,0,30"/>
            </StackPanel>
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="FULL NAME" Foreground="#888" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                    <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" Margin="0,0,0,20">
                        <TextBox x:Name="txtFullName" Padding="10" BorderThickness="0" FontSize="14"/>
                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="GENDER" Foreground="#888" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                            <ComboBox x:Name="cmbGender" Padding="10" Height="45" VerticalContentAlignment="Center">
                                <ComboBoxItem Content="Male" IsSelected="True"/>
                                <ComboBoxItem Content="Female"/>
                                <ComboBoxItem Content="Other"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="BIRTHDATE" Foreground="#888" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                            <DatePicker x:Name="dpBirthdate" Height="45" Padding="5" VerticalContentAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="CONTACT NUMBER" Foreground="#888" FontSize="12" FontWeight="Bold" Margin="0,20,0,8"/>
                    <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" Margin="0,0,0,20">
                        <TextBox x:Name="txtContact" Padding="10" BorderThickness="0" FontSize="14"/>
                    </Border>
                    <TextBlock Text="EMAIL ADDRESS" Foreground="#888" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                    <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" Margin="0,0,0,20">
                        <TextBox x:Name="txtEmail" Padding="10" BorderThickness="0" FontSize="14"/>
                    </Border>
                    <TextBlock Text="ADDRESS" Foreground="#888" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                    <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" Margin="0,0,0,20">
                        <TextBox x:Name="txtAddress" Padding="10" MinHeight="80" TextWrapping="Wrap" BorderThickness="0" FontSize="14"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="btnCancel" Click="btnCancel_Click" Content="CANCEL" Background="Transparent" Foreground="#888" FontWeight="Bold" Margin="0,0,20,0" BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="btnSave" Click="btnSave_Click" Content="SAVE CHANGES" Background="#A32A53" Foreground="White" FontWeight="Bold" Padding="25,12" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="25">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="25,12"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
