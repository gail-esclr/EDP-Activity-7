<Window x:Class="dermaClinic.ResentPassword"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reset Password" Height="720" Width="1280" 
        WindowStartupLocation="CenterScreen" WindowState="Maximized" Background="White">

        <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.5*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="#FDECEF">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid Width="140" Height="140" Margin="0,0,0,30">
                    <Ellipse Fill="White"/>
                    <Image Source="logo.png" Width="130" Height="130" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image.Clip>
                            <EllipseGeometry Center="65,65" RadiusX="65" RadiusY="65"/>
                        </Image.Clip>
                    </Image>
                </Grid>

                <TextBlock Text="D E R M A C A R E" FontFamily="Georgia" FontSize="36" Foreground="#333" HorizontalAlignment="Center"/>
                <TextBlock Text="D E R M A   C L I N I C" FontSize="12" Foreground="#888" HorizontalAlignment="Center" Margin="0,15,0,0" />

                <Border Height="1" Background="#D5C5C9" Width="180" Margin="0,30,0,30" />

                <TextBlock Text="C A R E   F O R   Y O U R   S K I N ," FontSize="11" Foreground="#888" HorizontalAlignment="Center" Margin="0,0,0,5" FontWeight="Medium"/>
                <TextBlock Text="L O V E   Y O U R   G L O W ." FontSize="11" Foreground="#888" HorizontalAlignment="Center" FontWeight="Medium"/>
            </StackPanel>
        </Grid>
        <Grid Grid.Column="1" Margin="80,0">
            <StackPanel VerticalAlignment="Center" MaxWidth="400">
                <TextBlock Text="Create New Password" FontFamily="Georgia"  FontSize="40"  Foreground="#333" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="Your new password must be different from previously used passwords." 
                           FontSize="14" Foreground="Gray" HorizontalAlignment="Center" Margin="0,10,0,40" 
                           TextWrapping="Wrap" TextAlignment="Center"/>
                <TextBlock Text="New Password" Foreground="#555" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" Margin="0,0,0,20" Padding="10,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🔒" VerticalAlignment="Center" Margin="5,0,10,0" Foreground="Gray" FontSize="16"/>
                        <PasswordBox x:Name="txtNewPassword" Grid.Column="1" BorderThickness="0" VerticalContentAlignment="Center" FontSize="16"/>
                    </Grid>
                </Border>
                <TextBlock Text="Confirm New Password" Foreground="#555" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" Margin="0,0,0,30" Padding="10,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🔒" VerticalAlignment="Center" Margin="5,0,10,0" Foreground="Gray" FontSize="16"/>
                        <PasswordBox x:Name="txtConfirmPassword" Grid.Column="1" BorderThickness="0" VerticalContentAlignment="Center" FontSize="16"/>
                    </Grid>
                </Border>
                <Button x:Name="btnResetPassword" Click="btnResetPassword_Click" Content="RESET PASSWORD" Background="#A32A53" Foreground="White" Height="55" FontSize="18" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#862342"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <TextBlock x:Name="btnCancelReturn" MouseLeftButtonDown="btnCancelReturn_Click" Text="Cancel and Return to Login" HorizontalAlignment="Center" Foreground="Gray" 
                           Margin="0,25,0,0" Cursor="Hand" TextDecorations="Underline"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>