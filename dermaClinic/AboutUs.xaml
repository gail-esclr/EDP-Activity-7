    <Window x:Class="dermaClinic.AboutUs"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About DermaCare" Height="900" Width="1500" 
        WindowStartupLocation="CenterScreen" WindowState="Maximized" Background="White">

    <Window.Resources>
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="25,0"/>
            <Setter Property="Margin" Value="10,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="25">
                            <StackPanel Orientation="Horizontal" Margin="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FADDE7" TargetName="border"/>
                                <Setter Property="Foreground" Value="#A32A53"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonActive" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Background" Value="#A32A53"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#862342"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Grid Grid.Column="0" Background="#FDECEF">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <StackPanel Grid.Row="0" Margin="30,40,0,40">
                <TextBlock Text="DERMACARE" FontFamily="Georgia" Foreground="#A32A53" FontSize="28" FontWeight="Bold"/>
                <TextBlock Text="DERMATOLOGY CLINIC" Foreground="#888" FontSize="10" FontWeight="SemiBold" Margin="2,0,0,0"/>
            </StackPanel>

            <StackPanel Grid.Row="1">
                <Button x:Name="btnDashboard" Click="Nav_Click" Style="{StaticResource NavButton}">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M3,13H11V3H3V13M3,21H11V15H3V21M13,21H21V11H13V21M13,3V9H21V3H13Z" Fill="#A32A53" Width="18" Height="18" Stretch="Fill" Margin="0,0,15,0"/>
                        <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="btnUsers" Click="Nav_Click" Style="{StaticResource NavButton}">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M16,13C15.71,13 15.38,13 15.03,13.05C16.19,13.89 17,15 17,16.5V19H23V16.5C23,14.17 18.33,13 16,13M8,13C5.67,13 1,14.17 1,16.5V19H15V16.5C15,14.17 10.33,13 8,13M8,11A3,3 0 0,0 11,8A3,3 0 0,0 8,5A3,3 0 0,0 5,8A3,3 0 0,0 8,11M16,11A3,3 0 0,0 19,8A3,3 0 0,0 16,5A3,3 0 0,0 13,8A3,3 0 0,0 16,11Z" Fill="#A32A53" Width="18" Height="18" Stretch="Fill" Margin="0,0,15,0"/>
                        <TextBlock Text="Users" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="btnPatients" Click="Nav_Click" Style="{StaticResource NavButton}">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M12,5.5A3.5,3.5 0 0,1 15.5,9A3.5,3.5 0 0,1 12,12.5A3.5,3.5 0 0,1 8.5,9A3.5,3.5 0 0,1 12,5.5M5,8C5.56,8 6.08,8.15 6.53,8.42C6.38,9.85 6.82,11.23 7.65,12.35C5.16,13.03 3,15.06 3,18V22H11V20.21C11,19.26 11.23,18.33 11.66,17.5H5V18M19,8C19.56,8 20.08,8.15 20.53,8.42C20.38,9.85 20.82,11.23 21.65,12.35C19.16,13.03 17,15.06 17,18V22H25V20.21C25,19.26 25.23,18.33 25.66,17.5H19V18" Fill="#A32A53" Width="18" Height="18" Stretch="Fill" Margin="0,0,15,0"/>
                        <TextBlock Text="Patients" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="btnDoctors" Click="Nav_Click" Style="{StaticResource NavButton}">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z" Fill="#A32A53" Width="16" Height="18" Stretch="Fill" Margin="0,0,15,0"/>
                        <TextBlock Text="Doctors" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="btnServices" Click="Nav_Click" Style="{StaticResource NavButton}">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M19,19H5V8H19M19,3H18V1H16V3H8V1H6V3H5C3.89,3 3,3.9 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5A2,2 0 0,0 19,3M16.53,11.06L15.47,10L10.5,14.97L8.53,13L7.47,14.06L10.5,17.09L16.53,11.06Z" Fill="#A32A53" Width="18" Height="18" Stretch="Fill" Margin="0,0,15,0"/>
                        <TextBlock Text="Services" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="btnAppointments" Click="Nav_Click" Style="{StaticResource NavButton}">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M19,19H5V8H19M16,1V3H8V1H6V3H5C3.89,3 3,3.89 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5C21,3.89 20.1,3 19,3H18V1M17,12H12V17H17V12Z" Fill="#A32A53" Width="18" Height="18" Stretch="Fill" Margin="0,0,15,0"/>
                        <TextBlock Text="Appointments" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="btnPayments" Click="Nav_Click" Style="{StaticResource NavButton}">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M20,8H4V6H20V8M20,18H4V12H20V18M20,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V6C22,4.89 21.1,4 20,4Z" Fill="#A32A53" Width="18" Height="18" Stretch="Fill" Margin="0,0,15,0"/>
                        <TextBlock Text="Payments" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="btnReports" Click="Nav_Click" Style="{StaticResource NavButton}">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M14,10H10V14H14V10M16,4H15V2H13V4H11V2H9V4H8C6.89,4 6,4.89 6,6V20A2,2 0 0,0 8,22H16A2,2 0 0,0 18,20V6C18,4.89 17.1,4 16,4M16,20H8V6H16V20Z" Fill="#A32A53" Width="16" Height="18" Stretch="Fill" Margin="0,0,15,0"/>
                        <TextBlock Text="Transaction Reports" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <Button x:Name="btnLogout" Click="btnLogout_Click" Grid.Row="2" Content="Log Out" Margin="30,0,0,40" Background="Transparent" BorderThickness="0" Foreground="#A32A53" FontWeight="SemiBold" FontSize="15" HorizontalAlignment="Left" Cursor="Hand"/>
        </Grid>

        <!-- Main Content -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="40,30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="About System" FontFamily="Georgia" FontSize="40" FontWeight="Bold" Foreground="#333"/>

                <Border Grid.Row="1" Background="White" CornerRadius="30" Padding="40" Margin="0,20,0,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="40" Opacity="0.08" ShadowDepth="10" Color="#A32A53"/>
                </Border.Effect>

                <Grid VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,30">
                        <Image Source="logo.png" Width="150" Height="150" Margin="0,0,0,20" Stretch="Uniform" HorizontalAlignment="Center"/>
                        <TextBlock Text="DermaCare" Foreground="#A32A53" FontSize="42" FontWeight="Black" FontFamily="Georgia" HorizontalAlignment="Center"/>
                        <TextBlock Text="INFORMATION SYSTEM" Foreground="#BDC3C7" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>

                    <TextBlock Grid.Row="1" TextWrapping="Wrap" TextAlignment="Center" Foreground="#555" FontSize="18" LineHeight="30" MaxWidth="750" HorizontalAlignment="Center" Margin="0,0,0,60">
                        At DermaCare, we provide expert skin care solutions through modern dermatological treatments focused on comfort, confidence, and healthy skin.
                    </TextBlock>

                    <Border Grid.Row="2" BorderBrush="#FEEFF5" BorderThickness="0,1,0,0" Padding="0,40,0,0">
                        <UniformGrid Columns="2">
                            <StackPanel HorizontalAlignment="Left" Margin="100,0">
                                <TextBlock Text="CRAFTED BY" Foreground="#BDC3C7" FontSize="11" FontWeight="Bold"/>
                                <TextBlock Text="DermaCare Development Team" Foreground="#A32A53" FontSize="16" FontWeight="SemiBold" Margin="0,5,0,0"/>
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Right" Margin="100,0">
                                <TextBlock Text="VERSION" Foreground="#BDC3C7" FontSize="11" FontWeight="Bold"/>
                                <TextBlock Text="v1.0.4 - Premium" Foreground="#A32A53" FontSize="16" FontWeight="SemiBold" Margin="0,5,0,0"/>
                            </StackPanel>
                        </UniformGrid>
                    </Border>

                    <Button Grid.Row="3" Content="Return to Dashboard" Click="Nav_Click" Name="btnDashboardBack"
                            Background="#A32A53" Foreground="White" Width="260" Height="55" 
                            FontSize="16" FontWeight="SemiBold" BorderThickness="0"
                            Margin="0,60,0,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="15"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Border>
        </Grid>
        </ScrollViewer>
    </Grid>
</Window>